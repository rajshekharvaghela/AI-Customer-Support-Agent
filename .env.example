# LLM Configuration (choose one or more)
# Priority: ChatGPT > Claude > Ollama Cloud (automatic fallback)

# OpenAI / ChatGPT Configuration (optional)
OPENAI_API_KEY=""
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude Configuration (optional)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama Cloud Configuration (default fallback - no API key needed for local models)
OLLAMA_CLOUD_API_KEY=""
OLLAMA_MODEL="minimax-m2.5:cloud"
OLLAMA_BASE_URL=https://api.ollama.com/v1

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Backend URL (for frontend)
BACKEND_URL=http://localhost:8000